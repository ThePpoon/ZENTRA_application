# ZENTRA — Environment Configuration (template)
# Copy to .env and fill in your real values:  cp .env.example .env
# ================================================================

# ── Roboflow / Inference Server ─────────────────────────────
# Local Docker inference server (default). Started by the launcher.
INFERENCE_SERVER_URL=http://localhost:9001
ROBOFLOW_API_KEY=your_roboflow_api_key_here
PPE_MODEL_ID=ppe-cpxsz/2
FALL_MODEL_ID=fall-detection-ovjqo/5
USE_LOCAL_MODEL=false

# ── Camera ───────────────────────────────────────────────────
# source: webcam | rtsp | file   (the desktop app overrides this at runtime)
CAMERA_SOURCE=webcam
WEBCAM_INDEX=0
USE_DSHOW=true
RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1
VIDEO_FILE_PATH=

# ── Inference cadence ────────────────────────────────────────
INFER_EVERY_N_FRAMES=3

# ── LINE OA Alerts (leave blank to disable LINE delivery) ────
# Events still appear in the desktop app even without these.
LINE_OA_CHANNEL_ACCESS_TOKEN=
LINE_OA_GROUP_SUPERVISOR=
LINE_OA_GROUP_SAFETY=
LINE_OA_GROUP_EMERGENCY=

# ── Daily report time (HH:MM, 24h) ──────────────────────────
DAILY_REPORT_TIME=20:00

# ── Training (tuned for a 4 GB GPU like RTX 3050) ───────────
# yolov8n = fastest/lightest, yolov8s = better accuracy if VRAM allows.
# yolov8m needs ~8 GB+; drop batch if you hit CUDA out-of-memory.
YOLO_BASE_MODEL=yolov8s.pt
TRAIN_DEVICE=0
TRAIN_BATCH_SIZE=4
TRAIN_EPOCHS=100
TRAIN_WORKERS=4

